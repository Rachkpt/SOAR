# ══════════════════════════════════════════════════════════════════
#  SOC Automation Pipeline — Configuration Template
#  Copier ce fichier en .env et remplir les valeurs
#  cp env.example .env  
# ══════════════════════════════════════════════════════════════════
#
#  ⚠️  IMPORTANT : Ne jamais mettre de commentaires après les valeurs
#  ❌  BLOCK_DURATION_MIN=10   ← commentaire inline (cause une erreur)
#  ✅  BLOCK_DURATION_MIN=10   (commentaire sur ligne séparée)
#
# ══════════════════════════════════════════════════════════════════

# ─── TheHive ──────────────────────────────────────────────────────
# URL de votre instance TheHive (ex: http://192.168.1.10:9000)
THEHIVE_URL=http://VOTRE_IP:9000

# Clé API TheHive (Profil utilisateur → API Key)
THEHIVE_APIKEY=votre_cle_api_thehive_ici

# ─── Cortex ───────────────────────────────────────────────────────
# URL de votre instance Cortex (ex: http://192.168.1.10:9001)
CORTEX_URL=http://VOTRE_IP:9001

# Clé API Cortex (Users → API Key)
CORTEX_APIKEY=votre_cle_api_cortex_ici

# ─── MISP ─────────────────────────────────────────────────────────
# URL de votre instance MISP (ex: https://192.168.1.11)
MISP_URL=https://VOTRE_IP_MISP

# Clé API MISP (Administration → Auth Keys → Add authentication key)
MISP_APIKEY=votre_cle_api_misp_ici

# Activer ou désactiver MISP (true/false)
MISP_ENABLED=true

# ─── VirusTotal ───────────────────────────────────────────────────
# Activer VirusTotal (true/false)
VT_ENABLED=true

# Clé API VirusTotal (gratuite sur virustotal.com)
VT_APIKEY=votre_cle_api_virustotal_ici

# Timeout des requêtes VT en secondes
VT_TIMEOUT=15

# Nombre minimum de détections pour verdict malveillant
VT_MIN_DETECTIONS=2

# ─── Service A — Webhook ──────────────────────────────────────────
# Interface d'écoute (0.0.0.0 = toutes les interfaces)
LISTEN_HOST=0.0.0.0

# Port d'écoute du webhook
LISTEN_PORT=5000

# Délai anti-doublon entre deux alertes identiques (secondes)
RATE_LIMIT_SEC=10

# Nombre de tentatives en cas d'échec
RETRY_ATTEMPTS=3

# Délai entre les tentatives (secondes)
RETRY_DELAY_SEC=5

# ─── Service B — Responder ────────────────────────────────────────
# Fréquence de poll TheHive (secondes)
POLL_INTERVAL=20

# Sévérité minimale pour traitement
MIN_SEVERITY=1

# Sévérité minimale pour réponse active
RESPONSE_MIN_SEV=2

# Fichier d'état des alertes traitées
STATE_FILE=responder_state.json

# Fichier de la blacklist IPs
BLACKLIST_FILE=ip_blacklist.txt

# Timeout attente résultats Cortex (secondes)
CORTEX_JOB_TIMEOUT=180

# ─── Réponse Active — Blocage Firewall ────────────────────────────
# ATTENTION : mettre true nécessite des droits admin/root
# false = mode simulation (les IPs ne sont pas vraiment bloquées)
ACTIVE_RESPONSE=false

# Durée de blocage en minutes
BLOCK_DURATION_MIN=10

# Bloquer aussi les IPs internes (true/false)
BLOCK_ALL_IPS=true

# Bloquer automatiquement les IPs détectées comme brute force
BLOCK_ON_BRUTEFORCE=true

# ─── Notifications Telegram ───────────────────────────────────────
# Activer les notifications Telegram (true/false)
TELEGRAM_ENABLED=false

# Token du bot Telegram (obtenu via @BotFather)
TELEGRAM_TOKEN=

# Chat ID Telegram (voir README pour obtenir votre ID)
TELEGRAM_CHAT_ID=

# ─── Notifications Gmail (optionnel) ─────────────────────────────
# Activer les notifications email (true/false)
GMAIL_ENABLED=false

# Adresse Gmail expéditrice
GMAIL_USER=

# Mot de passe d'application Gmail (pas votre vrai mot de passe)
# Générer sur : myaccount.google.com/apppasswords
GMAIL_PASS=

# Adresse destinataire
GMAIL_TO=

# ─── Logs ─────────────────────────────────────────────────────────
# Fichier log Service A
LOG_FILE=service_a.log

# Fichier log Service B
LOG_FILE_B=service_b.log

# Niveau de log : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Notifications (seuil de sévérité) ───────────────────────────
# Sévérité minimale pour envoyer une notification (1=Low, 2=Med, 3=High)
NOTIFY_MIN_SEV=1

