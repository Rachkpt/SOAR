# ══════════════════════════════════════════════════════════════════
#  SOC Automation Pipeline — Configuration
#  Rachad Lab
#  Copier ce fichier en .env et remplir les valeurs
# ══════════════════════════════════════════════════════════════════

# ─── TheHive ──────────────────────────────────────────────────────
THEHIVE_URL=http://10.2.3.122:9000
THEHIVE_APIKEY=J9LiEsGJDFFfDmBuAKyj+MUmWyytwNTx

# ─── Cortex ───────────────────────────────────────────────────────
CORTEX_URL=http://10.2.3.122:9001
CORTEX_APIKEY=bWlV+gaFN5SWvymWfk1u1Rp8tMWYnJG+

# ─── MISP ─────────────────────────────────────────────────────────
MISP_URL=https://10.2.3.121
MISP_APIKEY=fT4SirMbSXZeBZMIFSwQIXyaIW1smGmX6uuAOv1s
MISP_ENABLED=true

# ─── VirusTotal (gratuit : 500 req/jour) ──────────────────────────
# Clé gratuite sur : https://www.virustotal.com/gui/join-us
VT_ENABLED=true
VT_APIKEY=
VT_TIMEOUT=15
VT_MIN_DETECTIONS=2        # seuil : >= 2 détections = malveillant

# ─── Service A — Webhook ──────────────────────────────────────────
# URL pour Splunk : http://CETTE-IP:5000/alert
LISTEN_HOST=0.0.0.0
LISTEN_PORT=5000
RATE_LIMIT_SEC=10           # anti-flood : 1 alerte max / 10s par ref
RETRY_ATTEMPTS=3
RETRY_DELAY_SEC=5

# ─── Service B — Responder ────────────────────────────────────────
POLL_INTERVAL=30            # polling TheHive toutes les 30s
MIN_SEVERITY=3              # traiter les cas >= High (3)
RESPONSE_MIN_SEV=4          # réponse active seulement sur Critical (4)
STATE_FILE=responder_state.json
BLACKLIST_FILE=ip_blacklist.txt

# ─── Réponse active iptables ──────────────────────────────────────
# DANGER : mettre true SEULEMENT sur Linux avec droits root
# Les IPs internes (10.x, 192.168.x, 172.16.x) ne sont JAMAIS bloquées
ACTIVE_RESPONSE=false

# ─── Notifications Telegram ───────────────────────────────────────
# 1. Ouvre Telegram → @BotFather → /newbot → copie le TOKEN
# 2. Envoie /start au bot → curl https://api.telegram.org/botTOKEN/getUpdates
# 3. Copie "id" → TELEGRAM_CHAT_ID
TELEGRAM_ENABLED=false
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Notifications Gmail ──────────────────────────────────────────
# App Password : myaccount.google.com → Sécurité → Mots de passe d'application
GMAIL_ENABLED=false
GMAIL_USER=
GMAIL_PASS=
GMAIL_TO=

# ─── Logs ─────────────────────────────────────────────────────────
LOG_FILE=service_a.log
LOG_FILE_B=service_b.log
LOG_LEVEL=INFO              # DEBUG, INFO, WARNING, ERROR

# ─── Notifications (seuil) ────────────────────────────────────────
NOTIFY_MIN_SEV=3            # 3=High+Critical  4=Critical uniquement
