# ══════════════════════════════════════════════════════════════════
#  SOC Automation Pipeline — Template de Configuration
#
#  UTILISATION :
#    cp env.example .env
#    nano .env   (remplir toutes les valeurs)
#
#  ⚠️  RÈGLE CRITIQUE : JAMAIS de commentaire après une valeur !
#
#  ❌  INCORRECT (provoque une erreur Python) :
#      BLOCK_DURATION_MIN=10    ← durée en minutes
#
#  ✅  CORRECT :
#      # durée en minutes
#      BLOCK_DURATION_MIN=10
#
# ══════════════════════════════════════════════════════════════════

# ─── TheHive ──────────────────────────────────────────────────────
# URL de votre instance TheHive
# Exemple : http://192.168.1.10:9000
THEHIVE_URL=http://VOTRE_IP:9000

# Clé API TheHive
# Obtenir : TheHive → Profil utilisateur → API Key → Créer
THEHIVE_APIKEY=votre_cle_api_thehive_ici

# ─── Cortex ───────────────────────────────────────────────────────
# URL de votre instance Cortex
# Exemple : http://192.168.1.10:9001
CORTEX_URL=http://VOTRE_IP:9001

# Clé API Cortex
# Obtenir : Cortex → Organizations → Users → Create API Key
CORTEX_APIKEY=votre_cle_api_cortex_ici

# ─── MISP ─────────────────────────────────────────────────────────
# URL de votre instance MISP
# Exemple : https://192.168.1.11
MISP_URL=https://VOTRE_IP_MISP

# Clé API MISP
# Obtenir : MISP → Administration → Auth Keys → Add authentication key
MISP_APIKEY=votre_cle_api_misp_ici

# Activer ou désactiver MISP (true/false)
MISP_ENABLED=true

# ─── VirusTotal ───────────────────────────────────────────────────
# Activer VirusTotal (true/false)
VT_ENABLED=true

# Clé API VirusTotal
# Obtenir gratuitement : https://www.virustotal.com/gui/join-us
# Limite gratuite : 500 requêtes/jour, 4 requêtes/minute
VT_APIKEY=votre_cle_api_virustotal_ici

# Timeout des requêtes VirusTotal en secondes
VT_TIMEOUT=15

# Nombre minimum de moteurs qui détectent pour verdict "malveillant"
VT_MIN_DETECTIONS=2

# ─── Service A — Webhook ──────────────────────────────────────────
# Interface d'écoute (0.0.0.0 = toutes les interfaces réseau)
LISTEN_HOST=0.0.0.0

# Port d'écoute du webhook Splunk
LISTEN_PORT=5000

# Délai anti-doublon : ignore les alertes identiques dans ce délai (secondes)
RATE_LIMIT_SEC=10

# Nombre de tentatives en cas d'échec de création d'alerte TheHive
RETRY_ATTEMPTS=3

# Délai entre les tentatives (secondes)
RETRY_DELAY_SEC=5

# ─── Service B — Responder ────────────────────────────────────────
# Fréquence de vérification des nouvelles alertes TheHive (secondes)
POLL_INTERVAL=20

# Sévérité minimale pour traitement (1=Low, 2=Med, 3=High, 4=Critical)
MIN_SEVERITY=1

# Sévérité minimale pour réponse active (blocage, etc.)
RESPONSE_MIN_SEV=2

# Fichier JSON stockant les alertes déjà traitées
STATE_FILE=responder_state.json

# Fichier texte listant les IPs bloquées
BLACKLIST_FILE=ip_blacklist.txt

# Temps maximum d'attente des résultats Cortex en secondes
CORTEX_JOB_TIMEOUT=180

# ─── Réponse Active — Blocage Firewall ────────────────────────────
# ATTENTION : mettre true requiert des droits admin (Windows) ou root (Linux)
#
# false → mode SIMULATION : log les blocages sans les appliquer réellement
# true  → BLOCAGE RÉEL    : applique les règles firewall (netsh ou iptables)
ACTIVE_RESPONSE=false

# Durée de blocage des IPs en minutes (déblocage automatique après ce délai)
BLOCK_DURATION_MIN=10

# Bloquer aussi les IPs internes/privées (true/false)
BLOCK_ALL_IPS=true

# Bloquer automatiquement toute IP identifiée comme brute force (true/false)
BLOCK_ON_BRUTEFORCE=true

# ─── Notifications Telegram ───────────────────────────────────────
# Activer les notifications Telegram (true/false)
TELEGRAM_ENABLED=false

# Token du bot Telegram
# Obtenir : Telegram → @BotFather → /newbot → copier le token
TELEGRAM_TOKEN=

# Chat ID Telegram (votre identifiant de conversation)
# Obtenir : envoyer un message à votre bot, puis :
# curl "https://api.telegram.org/botVOTRE_TOKEN/getUpdates"
# Chercher : result[0].message.chat.id
TELEGRAM_CHAT_ID=

# ─── Notifications Gmail (optionnel) ─────────────────────────────
# Activer les notifications par email (true/false)
GMAIL_ENABLED=false

# Adresse Gmail expéditrice
GMAIL_USER=votre.adresse@gmail.com

# Mot de passe d'APPLICATION Gmail (pas votre vrai mot de passe !)
# Générer sur : myaccount.google.com/apppasswords
# Activer d'abord : Compte Google → Sécurité → Validation en 2 étapes
GMAIL_PASS=

# Adresse email destinataire des alertes
GMAIL_TO=destinataire@example.com

# ─── Logs ─────────────────────────────────────────────────────────
# Fichier de logs pour Service A
LOG_FILE=service_a.log

# Fichier de logs pour Service B
LOG_FILE_B=service_b.log

# Niveau de verbosité des logs
# Valeurs possibles : DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ─── Notifications — Seuil de sévérité ───────────────────────────
# Sévérité minimale pour envoyer une notification Telegram/Gmail
# 1=Low  2=Medium  3=High  4=Critical
NOTIFY_MIN_SEV=1
